{
  "manifest_version": 3,
  "name": "X 时间线下载",
  "description": "保存当前 X 页面已加载的时间线 JSON，并生成本地推文导出。",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "X 时间线下载"
  },
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "permissions": [
    "debugger",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.x.com/*",
    "https://api.twitter.com/*",
    "https://pbs.twimg.com/*"
  ],
  "minimum_chrome_version": "116"
}
